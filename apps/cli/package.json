{
  "name": "@specflow/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "specflow": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "specflow": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@specflow/specflow-kit": "workspace:*",
    "commander": "14.0.1"
  }
}
