{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@specflow/agent": ["packages/agent/src/index.ts"],
      "@specflow/core": ["packages/core/src/index.ts"],
      "@specflow/local-api": ["packages/local-api/src/index.ts"],
      "@specflow/shared": ["packages/shared/src/index.ts"],
      "@specflow/specflow": ["packages/specflow/src/index.ts"],
      "@specflow/runtime": ["packages/runtime/src/index.ts"],
      "@specflow/ui": ["packages/ui/src/index.tsx"]
    }
  }
}
